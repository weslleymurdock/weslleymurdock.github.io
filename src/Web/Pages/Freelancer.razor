@page "/freelancer"
@inject IBrowserStorageService Settings
@inject IJSRuntime JS
@inject ILocalizer Localizer
@implements IDisposable

<PageTitle>Freelancer | Portfólio</PageTitle>

<MudContainer Class="pa-10" Style="height:100vh;">
    <MudText Color=Color.Tertiary Typo="Typo.h3" GutterBottom="true" Align="Align.Center">@Localizer["AutonomousJobLabel"]</MudText>
    <MudText Color=Color.Tertiary Typo="Typo.subtitle1" Align="Align.Center" Class="mb-10">@Localizer["SolutionDevLabel"]</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader Class="glass-royal-bg border-bg">
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Architecture" Color="Color.Tertiary" Size="Size.Large" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Color=Color.Primary Typo="Typo.h6">@Localizer["ArchitectureLabel"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Color=Color.Primary Typo="Typo.body2">@Localizer["HelpLabel"]</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader Class="glass-royal-bg border-bg">
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Secondary" Size="Size.Large" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Color=Color.Primary Typo="Typo.h6">@Localizer["OptimizationLabel"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Color=Color.Primary Typo="Typo.body2">@Localizer["SourceAnalisysLabel"]</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code{

    private string _theme = "light";
    private string _language = "pt-BR";

    protected override async Task OnInitializedAsync()
    {
        Settings.OnSettingsChanged -= SettingsChanged;
        Settings.OnSettingsChanged += SettingsChanged;
        await Settings.InitializeAsync();
        _theme = await Settings.GetCurrentThemeAsync();
        await base.OnInitializedAsync();
    }

    public void Dispose() => Settings.OnSettingsChanged -= SettingsChanged;
    private void SettingsChanged()
    {
        _theme = Settings.Settings.Theme ?? "light";
        _language = Settings.Settings.Language ?? "pt-BR";
    }
}