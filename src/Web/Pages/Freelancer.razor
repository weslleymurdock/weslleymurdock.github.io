@page "/freelancer"
@inject IBrowserSettingsService Settings
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Freelancer | Portfólio</PageTitle>

<MudContainer Class="pa-10" Style="height:100vh;">
    <MudText Color=Color.Tertiary Typo="Typo.h3" GutterBottom="true" Align="Align.Center">Trabalho Autônomo & Consultoria</MudText>
    <MudText Color=Color.Tertiary Typo="Typo.subtitle1" Align="Align.Center" Class="mb-10">Desenvolvimento de soluções sob medida para clientes finais e empresas parceiras.</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader Class="glass-royal-bg">
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Architecture" Color="Color.Tertiary" Size="Size.Large" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Color=Color.Primary Typo="Typo.h6">Arquitetura e Desenho de Soluções</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Color=Color.Primary Typo="Typo.body2">Auxilio clientes a tirarem suas ideias do papel de forma técnica, escolhendo a melhor infraestrutura, banco de dados e arquitetura de software para garantir que o projeto escale.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader Class="glass-royal-bg">
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Secondary" Size="Size.Large" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Color=Color.Primary Typo="Typo.h6">Otimização e Resolução de Gargalos</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Color=Color.Primary Typo="Typo.body2">Análise de código-fonte de sistemas lentos em produção e reescrita de gargalos em .NET para trazer performance máxima e diminuir custos de nuvem.</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code{

    private string _theme = "light";
    private string _language = "pt-BR";

    protected override async Task OnInitializedAsync()
    {
        Settings.OnSettingsChanged -= SettingsChanged;
        Settings.OnSettingsChanged += SettingsChanged;
        await Settings.InitializeAsync();
        _theme = await Settings.GetCurrentThemeAsync();
        await base.OnInitializedAsync();
    }

    public void Dispose() => Settings.OnSettingsChanged -= SettingsChanged;
    private void SettingsChanged()
    {
        _theme = Settings.Settings.Theme ?? "light";
        _language = Settings.Settings.Language ?? "pt-BR";
    }
}