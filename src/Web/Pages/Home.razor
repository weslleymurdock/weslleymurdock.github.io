@page "/"
@inject IJSRuntime JS
@inject IBrowserStorageService Settings

@implements IDisposable

<PageTitle>@Localizer["HomePageTitle"]</PageTitle>

<MudContainer Class="mt-10 pa-10">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h2" Color=Color.Tertiary Align="Align.Center" Style="font-weight: 800;">@Localizer["JobTitle"]</MudText>
        <MudText Typo="Typo.h5" Color=Color.Tertiary Align="Align.Center" Class="mt-2">@Localizer["JobSubtitle"]</MudText>
    </div>

    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Class="mt-12 mb-6">@Localizer["HomePageCenterText"]</MudText>

    @if (_cards == null || _cards.Count <= 0)
    {
        <div class="d-flex pa-6 mt-6 mb-6 justify-center">
            <MudProgressCircular Color=Color.Tertiary Indeterminate="true" />
        </div>
    }
    else
    {
        <MudCarousel TData="Card" EnableSwipeGesture="true" AutoCycleTime="@TimeSpan.FromSeconds(5)" AutoCycle="true" ShowArrows="false" ShowBullets="false" Style="height: 420px;" Class="mud-width-full rounded-xl">
            @foreach (var card in _cards[_language])
            {
                <MudCarouselItem Class="d-flex justify-center align-center" Style="height: 100%;" Transition="Transition.Slide">
                    <MudCard Elevation="0" Class="ma-6 " Style="max-width: 800px; width: 100%;">
                        <MudCardHeader Class="glass-royal-bg border-bg " Style="width: 100%;">
                            <CardHeaderAvatar>
                                <MudIcon Icon="@card.icon" Size="Size.Large" Color="Color.Primary" />
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h5" Style="font-weight: 700;">@card.title</MudText>
                                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@card.subtitle</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="ma-6">
                            <MudText Color="Color.Dark" Typo="Typo.body1">@card.description</MudText>
                            <MudList T="MudText" Class="ma-2">
                                @foreach (var benefit in card.bulletPoints)
                                {
                                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                        <MudText Color="Color.Dark" Typo="Typo.h6">@benefit</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudCarouselItem>
            }
        </MudCarousel>
    }

    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Class="mt-16 mb-6">@Localizer["MainlyTechStacks"]</MudText>
    <MudGrid Justify="Justify.Center">
        @if (_skills == null)
        {
            <div class="d-flex justify-center mt-10">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            if (_skills.TryGetValue(_language, out var skills))
            {
                @foreach (var item in skills)
                {
                    <MudItem xs="12" md="4">
                        <MudCard Elevation="0" Class="ma-6 d-flex flex-column align-center" Style="height: 100%;">
                            <MudCardHeader Class="glass-royal-bg border-bg " Style="width:100%; height:15%">
                                <CardHeaderAvatar>
                                    <MudIcon Icon="@item.Icon" Size="Size.Large" Color="Color.Inherit" />
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Color=Color.Inherit Typo="Typo.h6" Style="font-weight: 600;">@item.Title</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudChipSet T=string Class="d-flex flex-wrap justify-center gap-2 mt-4">
                                    @foreach (var chip in item.Chips)
                                    {
                                        <MudChip T="string" Color=Color.Dark Variant="Variant.Filled" Class="rb-rr-gradient">@chip</MudChip>
                                    }
                                </MudChipSet>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12" md="4">
                    <MudCard Elevation="0" Class="ma-6 d-flex flex-column align-center" Style="height: 100%;">
                        <MudCardHeader Class="glass-royal-bg border-bg " Style="width:100%; height:15%">
                            <CardHeaderAvatar>
                                <MudIcon Icon="@Icons.Material.Filled.NotAccessible" Size="Size.Large" Color="Color.Inherit" />
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Color=Color.Inherit Typo="Typo.h6" Style="font-weight: 600;">Tradução não disponível</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent></MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>
</MudContainer>
@code {
    private Dictionary<string, Card[]>? _cards;
    private Dictionary<string, Skill[]>? _skills;
    private string _theme = "light";
    private string _language = "pt-BR";
    private bool _isAtTop = true;
    private string FabIcon => _isAtTop
        ? Icons.Material.Filled.KeyboardArrowDown
        : Icons.Material.Filled.KeyboardArrowUp;

    protected override async Task OnInitializedAsync()
    {
        Settings.OnSettingsChanged -= SettingsChanged;
        Settings.OnSettingsChanged += SettingsChanged;
        await Settings.InitializeAsync();
        _theme = await Settings.GetCurrentThemeAsync();
        _language = await Settings.GetCurrentLanguageAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _cards is null || _skills is null || _cards.Count <= 0 || _skills.Count <= 0)
        {
            await JS.InvokeVoidAsync("app.initGlass");
            _cards = await Http.GetFromJsonAsync<Dictionary<string, Card[]>>("data/cards.json");
            _skills = await Http.GetFromJsonAsync<Dictionary<string, Skill[]>>("data/items.json");

            _isAtTop = await JS.InvokeAsync<bool>("app.isAtTop");
            StateHasChanged();
        }
    }

    private void SettingsChanged()
    {
        _theme = Settings.Settings.Theme ?? "royal";
        _language = Settings.Settings.Language ?? "pt-BR";
        StateHasChanged();
    }

    public void Dispose() => Settings.OnSettingsChanged -= SettingsChanged;

}