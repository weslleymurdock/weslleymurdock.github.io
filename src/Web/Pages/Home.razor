@page "/"
@inject IJSRuntime JS
@inject IBrowserSettingsService Settings

@implements IDisposable

<PageTitle>@Localizer["HomePageTitle"]</PageTitle>

<MudContainer Class="mt-10 pa-10">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h2" Color="Color.Inherit" Align="Align.Center" Style="font-weight: 800;">@Localizer["JobTitle"]</MudText>
        <MudText Typo="Typo.h5" Color="Color.Inherit" Align="Align.Center" Class="mt-2">@Localizer["JobSubtitle"]</MudText>
    </div>

    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Class="mt-12 mb-6">@Localizer["HomePageCenterText"]</MudText>
    
    @if (cards == null)
    {
        <div class="d-flex pa-6 mt-6 mb-6 justify-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudCarousel TData="FeatureCard" EnableSwipeGesture="true" AutoCycleTime="@TimeSpan.FromSeconds(5)" AutoCycle="true" ShowArrows="true" ShowBullets="true" Style="height: 420px;" Class="mud-width-full rounded-xl">
            @foreach (var card in cards)
            {
                <MudCarouselItem Transition="Transition.Slide">
                    <div class=@("d-flex justify-center align-center " + (_theme == "dark" ? "glass-rgb-bg" : "glass-cmyk-bg")) style="height: 100%;">
                        <MudCard Elevation="0" Class="ma-6 d-flex flex-column align-center " Style="max-width: 600px; width: 100%;">
                            <div class="@(_theme == "dark" ? "glass-rgb-bg" : "glass-cmyk-bg")" style="width: 100%;">
                                <MudCardHeader Style="width: 100%;">
                                    <CardHeaderAvatar>
                                        <MudIcon Icon="@card.Icon" Size="Size.Large" Color="Color.Primary" />
                                    </CardHeaderAvatar>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h5" Style="font-weight: 700;">@card.Title</MudText>
                                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@card.Subtitle</MudText>
                                    </CardHeaderContent>
                                </MudCardHeader>
                            </div>
                            <MudCardContent Class="ma-6">
                                <MudText Color="Color.Dark" Typo="Typo.body1">@card.Description</MudText>
                                <MudList T="MudText" Class="ma-2">
                                    @foreach (var benefit in card.BulletPoints)
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                            <MudText Color="Color.Dark" Typo="Typo.h6">@benefit</MudText>
                                        </MudListItem>
                                    }
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </div>
                </MudCarouselItem>
            }
        </MudCarousel>
    }

    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Class="mt-16 mb-6">Stacks Principais</MudText>
    <MudGrid Justify="Justify.Center">
        @if (items == null)
        {
            <div class="d-flex justify-center mt-10">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            @foreach (var item in items)
            {
                <MudItem xs="12" md="4">
                    <MudCard Elevation="0" Class=@("ma-6 d-flex flex-column align-center "+ (_theme == "dark" ? "glass-rgb-bg" : "glass-cmyk-bg")) Style="height: 100%;">
                        <MudCardHeader Class="@(_theme == "dark" ? "glass-rgb-bg" : "glass-cmyk-bg")" Style="width:100%; height:15%">
                            <CardHeaderAvatar>
                                <MudIcon Icon="@item.Icon" Size="Size.Large" Color="Color.Primary" />
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@item.Title</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <div class="d-flex flex-wrap justify-center gap-2 mt-4">
                            @foreach (var chip in item.Chips)
                            {
                                <MudChip T="string" Color=Color.Dark Variant="Variant.Filled" Class="rb-rr-gradient">@chip</MudChip>
                            }
                        </div>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>
</MudContainer> 
@code {
    private List<FeatureCard>? cards;
    private List<SkillItem>? items;
    private string _theme = "light";
    private string _language = "pt-BR";
    private bool _isAtTop = true;
    private string FabIcon => _isAtTop
        ? Icons.Material.Filled.KeyboardArrowDown
        : Icons.Material.Filled.KeyboardArrowUp;

    protected override async Task OnInitializedAsync()
    {
        Settings.OnSettingsChanged -= SettingsChanged;
        Settings.OnSettingsChanged += SettingsChanged;
        await Settings.InitializeAsync();
        _theme = await Settings.GetCurrentThemeAsync();
        _language = await Settings.GetCurrentLanguageAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || cards is null || items is null || cards.Count <= 0 || items.Count <= 0)
        {
            await JS.InvokeVoidAsync("app.initGlass");
            cards = await Http.GetFromJsonAsync<List<FeatureCard>>("data/cards.json");
            items = await Http.GetFromJsonAsync<List<SkillItem>>("data/items.json");
 
            _isAtTop = await JS.InvokeAsync<bool>("app.isAtTop");
            StateHasChanged();
        }
    }

    private void SettingsChanged()
    {
        _theme = Settings.Settings.Theme;
        _language = Settings.Settings.Language;
        StateHasChanged();
    }

    private async Task OnFABClick()
    {
        await JS.InvokeVoidAsync(_isAtTop ? "app.scrollToBottom" : "app.scrollToTop");
        _isAtTop = !_isAtTop;
    }

    public void Dispose() => Settings.OnSettingsChanged -= SettingsChanged;

}