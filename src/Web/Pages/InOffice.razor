@page "/in-office"
@inject IBrowserSettingsService Settings
@implements IDisposable

<PageTitle>@Localizer["InOfficeActPageTitle"]</PageTitle>
<MudContainer Class="pa-10 ">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h2" Color="Color.Inherit" Align="Align.Center" Style="font-weight: 800;">@Localizer["InOfficeAct"]</MudText>
        <MudText Typo="Typo.h5" Color="Color.Inherit" Align="Align.Center" Class="mt-2 mb-10">@Localizer["InOfficeActDescription"]</MudText>
    </div>

    <MudTimeline TimelinePosition="TimelinePosition.Alternate">
   
        @if (experiences == null)
        {
            <div class="d-flex justify-center mt-10">
                <MudProgressCircular Color="Color.Success" Indeterminate="true" />
            </div>
        }
        else
        {
            @foreach (var item in experiences)
            {
                <MudTimelineItem Color="Color.Success" Elevation="25">
                    <ItemContent>
                        <MudPaper Class="@(_theme == "light" ? "glass-cmyk-bg" : "glass-rgb-bg")">
                            <MudPaper Class="pa-5">
                                <MudText Typo="Typo.h5" Color="Color.Surface">@item.Title</MudText>
                            </MudPaper>
                            <MudPaper Class=@("pa-5 ma-5 " + (_theme != "light" ? "glass-cmyk-bg" : "glass-rgb-bg"))>
                                <MudText Typo="Typo.h6">@item.Company (@(DateTime.Parse(@item.StartDate).ToString(System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern)) - @(DateTime.Parse(@item.EndDate).ToString(System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern)))</MudText>
                                <MudText Typo="Typo.body1" Class="mt-2" Color="Color.Dark"> @item.JobDescription </MudText>
                            </MudPaper>
                            <MudPaper Class=@("pa-5 ma-5 " + (_theme != "light" ? "glass-cmyk-bg" : "glass-rgb-bg"))>
                                <MudChipSet T="MudChip<MudText>" Class="ma-2" Color="Color.Dark" Size="Size.Small">
                                    @foreach (var tech in item.Technologies)
                                    {
                                        <MudChip T="MudText"  Size="Size.Medium" Color="Color.Dark"  Class="rb-rr-gradient" Variant="Variant.Filled"><MudText>@tech</MudText></MudChip>
                                    }
                                </MudChipSet>
                            </MudPaper>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>
            }
        }
    </MudTimeline>
</MudContainer>
@code {
    
    private string _theme = "light";
    private string _culture = "pt-BR";
    private List<InOfficeExperience>? experiences;

    protected override async Task OnInitializedAsync()
    {
        Settings.OnSettingsChanged -= SettingsChanged;
        Settings.OnSettingsChanged += SettingsChanged;
        await Settings.InitializeAsync();
        _theme = await Settings.GetCurrentThemeAsync();
        await base.OnInitializedAsync();
    }

    private void SettingsChanged()
    {
        _theme = Settings?.Settings?.Theme ?? "light";
        _culture = Settings?.Settings?.Language ?? "pt-BR";
        StateHasChanged();
    }

    public void Dispose() => Settings.OnSettingsChanged -= SettingsChanged;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || experiences == null || experiences.Count <= 0)
        {
            experiences = await Http.GetFromJsonAsync<List<InOfficeExperience>>("data/inoffice.json");

            StateHasChanged();
        }
        
        await base.OnAfterRenderAsync(firstRender);
    }
}