@using Web.Theme
@inherits LayoutComponentBase

@inject Application.Services.Abstract.IBrowserSettingsService SettingsService

@implements IDisposable


<MudThemeProvider @ref="@_mudThemeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="_customTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="rp-ap-gradient">
    <AppBar Open="@_drawerOpen" IsDark="@_isDarkMode" Language="@_language" />
    <MudDrawer Class="rp-ap-gradient" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="rp-ap-gradient">
        @Body
    </MudMainContent>
</MudLayout>


@code {
    private bool _drawerOpen = true;
    private MudThemeProvider _mudThemeProvider = default!;
    private MudTheme _customTheme = new MudTheme();
    private string _language;
    private bool _isDarkMode;
    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
    protected override async Task OnInitializedAsync()
    {
        SettingsService.OnSettingsChanged += OnSettingsChanged;

        await SettingsService.InitializeAsync();

        ApplySettings();
    }

    private void ApplySettings()
    {
        _isDarkMode = SettingsService.Settings.Theme == "dark";
        _customTheme = _isDarkMode ? AppTheme.RoyalBlueTheme : AppTheme.SkyBlueTheme;
        _language = SettingsService.Settings.Language ??= "pt-BR";
        CultureInfo culture = new(_language);
        culture.SetCurrentCulture(_language);
    }

    private async Task ToggleThemeAsync()
    {
        var newTheme = _isDarkMode ? "light" : "dark";
        _customTheme = _isDarkMode ? AppTheme.RoyalBlueTheme : AppTheme.SkyBlueTheme;
        await SettingsService.UpdateThemeAsync(newTheme);
    }

    private async Task ToggleLanguageAsync()
    {
        var culture = new CultureInfo(_language);
        culture.SetCurrentCulture(_language);
    }

    private async Task ChangeLanguageAsync(string lang)
    {
        await SettingsService.UpdateLanguageAsync(lang);
        StateHasChanged();
    }

    private void OnSettingsChanged()
    {
        ApplySettings();
        StateHasChanged();
    }

    public void Dispose()
    {
        SettingsService.OnSettingsChanged -= OnSettingsChanged;
    }
}