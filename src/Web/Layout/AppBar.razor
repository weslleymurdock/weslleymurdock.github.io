@inject Application.Services.Abstract.IBrowserSettingsService SettingsService
@inject IAppLocalizer Localizer
@implements IDisposable


<MudAppBar Elevation="1" Class="rp-ap-gradient">
    <MudIconButton Icon="@(Open ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)" Color=Color.Inherit Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
    <MudText Typo="Typo.h3" Class="ml-2">@Localizer["ApplicationTitle"]</MudText>
    <MudSpacer /> 
    <MudIconButton Icon="@(IsDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                    Color=Color.Inherit 
                    OnClick="OnToggleAsync" />

    <MudMenu Icon="@Icons.Material.Filled.Language" Color=Color.Inherit Dense="true">
        <MudMenuItem OnClick='() => OnMenuItemClickAsync("pt-BR")'>Português</MudMenuItem>
        <MudMenuItem OnClick='() => OnMenuItemClickAsync("en-US")'>English</MudMenuItem>
    </MudMenu>
     
    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color=Color.Inherit Edge="Edge.End" />
</MudAppBar>

@code {
    [Parameter] public bool Open { get; set; } = false;
    [Parameter] public bool IsDark { get; set; } = false;
    [Parameter] public string Language { get; set; } = string.Empty;
    [Parameter] public System.Action? LanguageToggled { get;set; } 
    
    private async Task OnMenuItemClickAsync(string language)
    {
        Language = language ??= "pt-BR";
        await ChangeLanguageAsync(language);
    }

    protected override async Task OnInitializedAsync()
    {
        await SettingsService.InitializeAsync();
        SettingsService.OnSettingsChanged += OnSettingsChanged;
        await base.OnInitializedAsync();
    } 
    private void DrawerToggle()
    {
        Open = !Open;
    }
    private void OnSettingsChanged()
    {
        ApplySettings();
        StateHasChanged();
    }

    private void ApplySettings()
    {
        IsDark = SettingsService.Settings.Theme == "dark";
    }

    protected async Task OnToggleAsync()
    {
        var newTheme = IsDark ? "light" : "dark";
        await SettingsService.UpdateThemeAsync(newTheme);
    }

    private async Task ChangeLanguageAsync(string lang)
    {
        CultureInfo ci = new CultureInfo(Language);
        ci.SetCurrentCulture(Language);

        await SettingsService.UpdateLanguageAsync(lang);
        StateHasChanged();
    }

    public void Dispose()
    {
        SettingsService.OnSettingsChanged -= OnSettingsChanged;
    }
}